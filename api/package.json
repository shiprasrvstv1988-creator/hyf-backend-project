{
  "name": "api",
  "private": true,
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": "^20.12.1",
    "npm": "^10.5.0"
  },
  "scripts": {
    "dev": "nodemon src/index.mjs",
    "start": "node src/index.mjs",
    "format": "npx prettier . --write",
    "check": "npx eslint . --fix",
    "db:migrate": "npx knex migrate:latest",
    "db:seed": "npx knex seed:run",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:migrate:make": "npx knex migrate:make",
    "db:seed:make": "npx knex seed:make"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.5",
    "deepmerge": "^4.3.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-list-endpoints": "^7.1.1",
    "knex": "^3.1.0",
    "mysql2": "^3.10.0",
    "pg": "^8.11.5",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  },
  "imports": {
    "#configs/*": "./src/configs/*",
    "#configs/knex-config.js": "./src/configs/knex-config.js",
    "#controllers/*": "./src/controllers/*",
    "#middlewares": "./src/middlewares/index.js",
    "#middlewares/*": "./src/middlewares/*",
    "#models/*": "./src/models/*",
    "#routers": "./src/routers/index.js",
    "#routers/*": "./src/routers/*",
    "#schemas/*": "./src/schemas/*"
  }
}
